rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId
    // Fields:
    //   - uid: string (required)
    //   - displayName: string
    //   - email: string (required)
    //   - educationLevel: string
    //   - targetExams: list
    //   - strengths: list
    //   - weaknesses: list
    //   - availableHours: number
    //   - buddyType: string
    //   - buddyId: string
    //   - createdAt: timestamp
    //
    // Collection: schedules
    // Document ID: scheduleId
    // Fields:
    //   - userId: string (required)
    //   - date: string (required)
    //   - blocks: list (required)
    //
    // Collection: studySessions
    // Document ID: sessionId
    // Fields:
    //   - userId: string (required)
    //   - subject: string (required)
    //   - durationMinutes: number (required)
    //   - startTime: timestamp (required)
    //   - endTime: timestamp
    //   - buddyId: string
    //
    // Collection: quizResults
    // Document ID: resultId
    // Fields:
    //   - userId: string (required)
    //   - subject: string (required)
    //   - score: number (required)
    //   - totalQuestions: number (required)
    //   - date: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isValidUser(data) {
      return data.uid is string && data.uid.size() > 0 &&
             data.email is string && data.email.size() > 0 &&
             (!('displayName' in data) || (data.displayName is string && data.displayName.size() < 100)) &&
             (!('educationLevel' in data) || data.educationLevel in ['Secondary', 'University']) &&
             (!('availableHours' in data) || (data.availableHours is number && data.availableHours >= 0 && data.availableHours <= 24)) &&
             (!('subjects' in data) || (data.subjects is list && data.subjects.size() <= 20)) &&
             (!('practiceGoals' in data) || (data.practiceGoals is list && data.practiceGoals.size() <= 20));
    }

    function isValidSchedule(data) {
      return data.userId is string && data.userId == request.auth.uid &&
             data.date is string &&
             data.blocks is list && data.blocks.size() <= 50;
    }

    function isValidStudySession(data) {
      return data.userId is string && data.userId == request.auth.uid &&
             data.subject is string && data.subject.size() > 0 &&
             data.durationMinutes is number && data.durationMinutes >= 0;
    }

    function isValidQuizResult(data) {
      return data.userId is string && data.userId == request.auth.uid &&
             data.subject is string && data.subject.size() > 0 &&
             data.score is number && data.score >= 0 &&
             data.totalQuestions is number && data.totalQuestions > 0;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);
    }

    match /schedules/{scheduleId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidSchedule(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidSchedule(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /studySessions/{sessionId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidStudySession(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidStudySession(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /quizResults/{resultId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidQuizResult(request.resource.data);
      allow update: if isAuthenticated() && isDocOwner() && isValidQuizResult(request.resource.data);
      allow delete: if isAuthenticated() && isDocOwner();
    }

    match /test/connection {
      allow read: if true;
    }

    // Default deny
    match /{path=**} {
      allow read, write: if false;
    }
  }
}
