{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile and study preferences",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "educationLevel": { "type": "string", "enum": ["Secondary", "University"] },
        "targetExams": { "type": "array", "items": { "type": "string" } },
        "strengths": { "type": "array", "items": { "type": "string" } },
        "weaknesses": { "type": "array", "items": { "type": "string" } },
        "availableHours": { "type": "number" },
        "buddyType": { "type": "string", "enum": ["AI", "Contact", "Guardian", "AppUser"] },
        "buddyName": { "type": "string" },
        "buddyId": { "type": "string" },
        "buddyRating": { "type": "number" },
        "buddyAlwaysPicksCalls": { "type": "boolean" },
        "buddyCaresAboutStudies": { "type": "boolean" },
        "subjects": { "type": "array", "items": { "type": "string" } },
        "practiceGoals": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "subject": { "type": "string" },
              "targetQuizzes": { "type": "number" },
              "targetScore": { "type": "number" }
            }
          } 
        },
        "studyStartTime": { "type": "string" },
        "studyEndTime": { "type": "string" },
        "achievements": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email", "educationLevel", "targetExams", "strengths", "weaknesses", "availableHours", "buddyType", "subjects", "achievements", "createdAt"]
    },
    "Schedule": {
      "title": "Schedule",
      "description": "Daily study schedule for a user",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string" },
        "blocks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "startTime": { "type": "string" },
              "endTime": { "type": "string" },
              "subject": { "type": "string" },
              "type": { "type": "string", "enum": ["Study", "Break", "Rest"] },
              "completed": { "type": "boolean" }
            },
            "required": ["startTime", "endTime", "subject", "type", "completed"]
          }
        }
      },
      "required": ["userId", "date", "blocks"]
    },
    "StudySession": {
      "title": "StudySession",
      "description": "A recorded study session",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "subject": { "type": "string" },
        "durationMinutes": { "type": "number" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "buddyId": { "type": "string" }
      },
      "required": ["userId", "subject", "durationMinutes", "startTime"]
    },
    "QuizResult": {
      "title": "QuizResult",
      "description": "Result of a completed quiz",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "subject": { "type": "string" },
        "score": { "type": "number" },
        "totalQuestions": { "type": "number" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "subject", "score", "totalQuestions", "date"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile data"
    },
    "/schedules/{scheduleId}": {
      "schema": "Schedule",
      "description": "User study schedules"
    },
    "/sessions/{sessionId}": {
      "schema": "StudySession",
      "description": "User study sessions"
    },
    "/quizResults/{resultId}": {
      "schema": "QuizResult",
      "description": "User quiz results"
    }
  }
}
